# MapLibre base style (free, CARTO Voyager)
NEXT_PUBLIC_MAPLIBRE_STYLE=https://basemaps.cartocdn.com/gl/voyager-gl-style/style.json

# Hal fiyatları CSV (acikveri.bizizmir.com — CKAN dataset CSV indirme bağlantısı)
HAL_CSV_URL=

# Vercel Cron Job için (rastgele uzun bir string)
CRON_SECRET=
